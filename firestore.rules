rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default-deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    function isEmailVerified() {
       return request.auth.token.email_verified == true;
    }
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // User Profile
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create, update: if isOwner(userId) && isEmailVerified() && (
        request.resource.data.keys().hasAll(['userId', 'mainGoal', 'mandarinLevel', 'targetRole']) &&
        request.resource.data.userId == userId
      );

      // Goals Subcollection
      match /goals/{goalId} {
        allow list, get: if isOwner(userId);
        allow create: if isOwner(userId) && isEmailVerified() && (
          request.resource.data.keys().hasAll(['title', 'type', 'progress']) &&
          request.resource.data.title is string && 
          request.resource.data.progress is number &&
          request.resource.data.progress >= 0 && request.resource.data.progress <= 100
        );
        allow update: if isOwner(userId) && isEmailVerified() && (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['progress', 'title', 'type'])
        );
        allow delete: if isOwner(userId);
      }

      // Logs Subcollection
      match /logs/{logId} {
        allow list, get: if isOwner(userId);
        allow create: if isOwner(userId) && isEmailVerified() && (
           request.resource.data.keys().hasAll(['date', 'createdAt']) &&
           request.resource.data.date is string &&
           request.resource.data.createdAt is string
        );
        allow update, delete: if isOwner(userId);
      }
    }
  }
}
